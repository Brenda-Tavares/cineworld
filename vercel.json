{
  "routes": [
    { "src": "/sitemap.xml", "dest": "/front-end/sitemap.xml" },
    { "src": "/robots.txt", "dest": "/front-end/robots.txt" },
    { "src": "/api/movies", "dest": "/api/movies.js" },
    { "src": "/api/movie", "dest": "/api/movie.js" },
    { "src": "/api/genres", "dest": "/api/genres.js" },
    { "src": "/api/streaming", "dest": "/api/streaming.js" },
    { "src": "/api/ai-search", "dest": "/api/ai-search.js" },
    { "src": "/sobre(/.*)?", "dest": "/front-end/sobre.html" },
    { "src": "/privacidade(/.*)?", "dest": "/front-end/privacidade.html" },
    { "src": "/termos(/.*)?", "dest": "/front-end/termos.html" },
    { "src": "/en/sobre", "dest": "/front-end/en/sobre.html" },
    { "src": "/en/privacidade", "dest": "/front-end/en/privacidade.html" },
    { "src": "/en/termos", "dest": "/front-end/en/termos.html" },
    { "src": "/es/sobre", "dest": "/front-end/es/sobre.html" },
    { "src": "/es/privacidade", "dest": "/front-end/es/privacidade.html" },
    { "src": "/es/termos", "dest": "/front-end/es/termos.html" },
    { "src": "/zh/sobre", "dest": "/front-end/zh/sobre.html" },
    { "src": "/zh/privacidade", "dest": "/front-end/zh/privacidade.html" },
    { "src": "/zh/termos", "dest": "/front-end/zh/termos.html" },
    { "src": "/ja/sobre", "dest": "/front-end/ja/sobre.html" },
    { "src": "/ja/privacidade", "dest": "/front-end/ja/privacidade.html" },
    { "src": "/ja/termos", "dest": "/front-end/ja/termos.html" },
    { "src": "/ru/sobre", "dest": "/front-end/ru/sobre.html" },
    { "src": "/ru/privacidade", "dest": "/front-end/ru/privacidade.html" },
    { "src": "/ru/termos", "dest": "/front-end/ru/termos.html" },
    { "src": "/ko/sobre", "dest": "/front-end/ko/sobre.html" },
    { "src": "/ko/privacidade", "dest": "/front-end/ko/privacidade.html" },
    { "src": "/ko/termos", "dest": "/front-end/ko/termos.html" },
    { "handle": "filesystem" },
    { "src": "/(.*)", "dest": "/front-end/index.html" }
  ],
  "trailingSlash": false,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection", "value": "1; mode=block" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' https://cdnjs.cloudflare.com https://pagead2.googlesyndication.com https://www.googletagmanager.com https://www.google-analytics.com https://www.google.com https://www.gstatic.com; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; img-src 'self' https://image.tmdb.org https://upload.wikimedia.org https://www.google-analytics.com https://pagead2.googlesyndication.com data:; connect-src 'self' https://api.themoviedb.org; font-src 'self' https://fonts.gstatic.com data:; frame-src 'self' https://www.google.com https://pagead2.googlesyndication.com; object-src 'none'; base-uri 'self'" }
      ]
    },
    {
      "source": "/front-end/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}